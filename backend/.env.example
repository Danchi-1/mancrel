# Copy this file to .env and fill in your values.
# Never commit .env to git — it's already in .gitignore.

# ── OpenRouter (LLM reply generation) ────────────────────────────────────────
# Get a free key at https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_key_here

# Free models you can use (pick one — check current availability at openrouter.ai/models):
#   qwen/qwen3-8b:free
#   deepseek/deepseek-r1-0528:free
#   google/gemma-3-27b-it:free
#   mistralai/mistral-7b-instruct:free
OPENROUTER_MODEL=qwen/qwen3-8b:free

# ── App identity (sent to OpenRouter for routing/analytics) ──────────────────
APP_URL=http://localhost:8000
